generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ModelPricingSnapshot {
  id              String   @id @default(cuid())
  modelId         String
  provider        String
  displayName     String   @default("")
  inputPerMTok    Float
  outputPerMTok   Float
  contextWindow   Int?
  maxOutputTokens Int?
  source          String   @default("fetched") // "fetched" | "seed" | "admin"
  status          String?  // "active" | "deprecated" | "preview" | null
  confidence      String   @default("high") // "high" | "low"
  agentApprovals  Int?
  agentTotal      Int?
  launchDate      DateTime?
  createdAt       DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([createdAt])
}

model ImagePricingSnapshot {
  id                String   @id @default(cuid())
  modelId           String
  provider          String
  displayName       String   @default("")
  pricePerImage     Float
  pricePerMegapixel Float?
  defaultResolution String   @default("1024x1024")
  qualityTier       String   @default("standard")
  maxResolution     String?
  supportedFormats  String[] @default(["png"])
  source            String   @default("fetched")
  status            String?
  confidence        String   @default("high")
  agentApprovals    Int?
  agentTotal        Int?
  launchDate        DateTime?
  createdAt         DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([createdAt])
}

model FetchRunLog {
  id             String   @id @default(cuid())
  provider       String
  modelsFound    String[]
  modelsMissing  String[]
  modelsNew      String[]
  totalExtracted Int
  error          String?
  createdAt      DateTime @default(now())

  @@index([provider, createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  keyPrefix  String
  email      String?
  rateLimit  Int       @default(500)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([keyHash])
}

model FetcherConfig {
  id                 String   @id @default("singleton")
  extractionProvider String   @default("anthropic")
  extractionModel    String   @default("claude-haiku-4-5-20251001")
  verificationAgents Json     @default("[{\"provider\":\"anthropic\",\"model\":\"claude-haiku-4-5-20251001\"},{\"provider\":\"openai\",\"model\":\"gpt-4.1-mini\"},{\"provider\":\"google\",\"model\":\"gemini-2.5-flash\"}]")
  arbitratorAgent    Json?    // Optional "general chair" agent: {"provider":"anthropic","model":"claude-sonnet-4-5-20250514"}
  maxTextLength      Int      @default(15000)
  enabled            Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model FetchRunSummary {
  id               String   @id @default(cuid())
  status           String   // 'success' | 'partial' | 'failed' | 'resolved'
  providersRun     Int
  modelsVerified   Int
  modelsFlagged    Int
  verificationCost Float
  errors           String[]
  createdAt        DateTime @default(now())

  @@index([createdAt])
}

model ApiUsageLog {
  id           String   @id @default(cuid())
  provider     String
  model        String
  operation    String   @default("pricing_extraction")
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  durationMs   Int?
  error        String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([provider, createdAt])
}

model VideoPricingSnapshot {
  id            String   @id @default(cuid())
  modelId       String
  provider      String
  displayName   String   @default("")
  costPerMinute Float
  inputType     String?
  resolution    String?
  maxDuration   Int?
  qualityMode   String?
  source        String   @default("fetched")
  status        String?
  confidence    String   @default("high")
  agentApprovals Int?
  agentTotal    Int?
  launchDate    DateTime?
  createdAt     DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([createdAt])
}

model AvatarPricingSnapshot {
  id             String   @id @default(cuid())
  modelId        String
  provider       String
  displayName    String   @default("")
  costPerMinute  Float
  avatarType     String?  // "standard" | "premium" | "translation" | "streaming"
  resolution     String?
  maxDuration    Int?
  qualityMode    String?
  lipSync        Boolean?
  source         String   @default("fetched")
  status         String?
  confidence     String   @default("high")
  agentApprovals Int?
  agentTotal     Int?
  launchDate     DateTime?
  createdAt      DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([createdAt])
}

model TtsPricingSnapshot {
  id                 String   @id @default(cuid())
  modelId            String
  provider           String
  displayName        String   @default("")
  costPerMChars      Float                         // $/1M characters
  voiceType          String?                       // "standard" | "neural" | "wavenet" | "hd"
  maxCharacters      Int?                          // max chars per request
  supportedLanguages Int?                          // number of supported languages
  source             String   @default("fetched")
  status             String?
  confidence         String   @default("high")
  agentApprovals     Int?
  agentTotal         Int?
  launchDate         DateTime?
  createdAt          DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([createdAt])
}

model SttPricingSnapshot {
  id                 String   @id @default(cuid())
  modelId            String
  provider           String
  displayName        String   @default("")
  costPerMinute      Float
  sttType            String?                       // "batch" | "streaming" | "real-time"
  maxDuration        Int?                          // max audio duration in seconds
  supportedLanguages Int?
  source             String   @default("fetched")
  status             String?
  confidence         String   @default("high")
  agentApprovals     Int?
  agentTotal         Int?
  launchDate         DateTime?
  createdAt          DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([createdAt])
}

model SdkTelemetryPing {
  id        String   @id @default(cuid())
  sdk       String   // "js" | "python"
  version   String
  runtime   String
  ip        String
  userAgent String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([sdk, createdAt])
}
