generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ModelPricingSnapshot {
  id              String   @id @default(cuid())
  modelId         String
  provider        String
  displayName     String   @default("")
  inputPerMTok    Float
  outputPerMTok   Float
  contextWindow   Int?
  maxOutputTokens Int?
  source          String   @default("fetched") // "fetched" | "seed" | "admin"
  createdAt       DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([createdAt])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  keyPrefix  String
  email      String?
  rateLimit  Int       @default(500)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([keyHash])
}

model FetcherConfig {
  id                 String   @id @default("singleton")
  extractionProvider String   @default("anthropic")
  extractionModel    String   @default("claude-haiku-4-5-20251001")
  maxTextLength      Int      @default(8000)
  enabled            Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model ApiUsageLog {
  id           String   @id @default(cuid())
  provider     String
  model        String
  operation    String   @default("pricing_extraction")
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  durationMs   Int?
  error        String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([provider, createdAt])
}
