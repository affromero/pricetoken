# PostgreSQL — pricing snapshots + API keys
DATABASE_URL=postgresql://pricetoken:pricetoken@localhost:5432/pricetoken

# Redis — response caching (5min TTL) + API rate limiting (sliding window)
# Optional in dev: rate limiting + caching degrade gracefully without Redis
REDIS_URL=redis://localhost:6379

# Anthropic API key — powers the AI pricing extractor (Claude Haiku)
# The fetcher scrapes provider pricing pages, then uses Claude to extract
# structured pricing data (modelId, input/output per MTok, context window)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — alternative extraction provider (GPT-4.1-mini)
# Only needed if you switch the admin config to use OpenAI for extraction
OPENAI_API_KEY=sk-...

# Google AI API key — alternative extraction provider (Gemini 2.5 Flash)
# Only needed if you switch the admin config to use Google for extraction
GOOGLE_AI_API_KEY=...

# Admin IP allowlist — comma-separated IPs that can access /admin/* and /api/admin/*
# Leave empty to deny all admin access (safe default)
ADMIN_ALLOWED_IPS=127.0.0.1

# Cloudflare (one-time DNS + email routing setup, not needed for daily operation)
# Run: npm run setup-dns
CF_DNS_API_TOKEN=...
CF_ZONE_ID=...
CF_ACCOUNT_ID=...
HETZNER_IP=...

# Email forwarding — catch-all *@pricetoken.ai forwards to this address
# Destination must be verified (Cloudflare sends a confirmation email)
EMAIL_FORWARD_TO=...
