{
  "name": "pricetoken-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "doppler run -- npm run dev --workspace=@pricetoken/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "ci:python": "cd packages/sdk-python && uv run ruff check && uv run ruff format --check && uv run mypy src && uv run pytest",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build && npm run ci:python",
    "seed": "doppler run -- npx tsx scripts/seed.ts",
    "seed-video": "doppler run -- npx tsx scripts/seed-video.ts",
    "fetch-pricing": "doppler run -- npx tsx scripts/fetch-pricing.ts",
    "fetch-image-pricing": "doppler run -- npx tsx scripts/fetch-image-pricing.ts",
    "seed-avatar": "doppler run -- npx tsx scripts/seed-avatar.ts",
    "seed-tts": "doppler run -- npx tsx scripts/seed-tts.ts",
    "seed-stt": "doppler run -- npx tsx scripts/seed-stt.ts",
    "fetch-avatar-pricing": "doppler run -- npx tsx scripts/fetch-avatar-pricing.ts",
    "fetch-video-pricing": "doppler run -- npx tsx scripts/fetch-video-pricing.ts",
    "fetch-tts-pricing": "doppler run -- npx tsx scripts/fetch-tts-pricing.ts",
    "fetch-stt-pricing": "doppler run -- npx tsx scripts/fetch-stt-pricing.ts",
    "setup-dns": "doppler run -- npx tsx scripts/setup-dns.ts",
    "update-static": "npx tsx scripts/update-static.ts",
    "generate-static": "npx tsx scripts/generate-static.ts",
    "generate-static:check": "npx tsx scripts/generate-static.ts --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-next": "^0.0.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
